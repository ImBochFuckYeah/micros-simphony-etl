  "dependencies": {
    "axios": "^1.16.0",
    "dotenv": "^16.4.5",
    "mssql": "^11.0.1",
    "node-cron": "^4.2.1",
    "ssh2-sftp-client": "^12.0.1"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.7",
    "@types/node": "^22.10.1",
