{
  "name": "micros-simphony-etl",
  "version": "1.0.0",
  "description": "Automated integration service built with Node.js to fetch Oracle MICROS Simphony POS sales data (JSON) via SFTP, persist it in SQL Server, and sync it to SAP Business One via Service Layer.",
  "main": "dist/app.js",
  "scripts": {
    "test": "tsx --test src/**/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/app.ts",
    "start": "node dist/app.js",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImBochFuckYeah/micros-simphony-etl.git"
  },
